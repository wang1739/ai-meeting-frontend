generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String               @id
  email           String               @unique
  name            String
  passwordHash    String               @map("password_hash")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  ChatMessage     ChatMessage[]
  Meeting         Meeting[]
  MeetingParticipant MeetingParticipant[]

  @@map("user")
}

model Meeting {
  id                   String                 @id
  title                String
  date                 String?
  startTime            DateTime?              @map("start_time")
  endTime              DateTime?              @map("end_time")
  status               String                 @default("scheduled")
  backgroundInfo       String?                @map("background_info")
  agenda               String?
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  creatorId            String                 @map("creator_id")
  creator              User                   @relation(fields: [creatorId], references: [id])
  ActionItem           ActionItem[]
  ChatMessage          ChatMessage[]
  MeetingParticipant   MeetingParticipant[]
  MeetingSummary       MeetingSummary[]
  TranscriptionSegment TranscriptionSegment[]

  @@map("meeting")
}

model MeetingParticipant {
  id         String   @id
  userId     String   @map("user_id")
  meetingId  String   @map("meeting_id")
  role       String   @default("guest")
  isSpeaker  Boolean  @default(false) @map("is_speaker")
  createdAt  DateTime @default(now()) @map("created_at")
  Meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_participant")
}

model MeetingSummary {
  id           String   @id
  meetingId    String   @map("meeting_id")
  summaryType  String   @map("summary_type")
  content      String
  generatedAt  DateTime @default(now()) @map("generated_at")
  modelVersion String?  @map("model_version")
  Meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_summary")
}

model ActionItem {
  id              String    @id
  meetingId       String    @map("meeting_id")
  description     String
  assigneeName    String?   @map("assignee_name")
  assigneeUserId  String?   @map("assignee_user_id")
  dueDate         DateTime? @map("due_date")
  status          String    @default("open")
  sourceSegmentId BigInt?   @map("source_segment_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  Meeting         Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("action_item")
}

model ChatMessage {
  id         String   @id
  meetingId  String   @map("meeting_id")
  userId     String   @map("user_id")
  userName   String   @map("user_name")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  Meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id])

  @@map("chat_message")
}

model TranscriptionSegment {
  id           String   @id
  meetingId    String   @map("meeting_id")
  speakerLabel String   @map("speaker_label")
  text         String
  startTimeMs  Int      @map("start_time_ms")
  endTimeMs    Int      @map("end_time_ms")
  isFinal      Boolean  @default(true) @map("is_final")
  createdAt    DateTime @default(now()) @map("created_at")
  Meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("transcription_segment")
}
